-- ==================== CREAR SCHEDULE SI NO EXISTE ====================
IF NOT EXISTS (SELECT 1 FROM sysschedules WHERE name = 'Cada_10_Minutos_AlertasBloqueos')
BEGIN
    EXEC sp_add_schedule
        @schedule_name = 'Cada_10_Minutos_AlertasBloqueos',
        @freq_type = 4, -- Diariamente
        @freq_interval = 1,
        @freq_subday_type = 2, -- Minutos
        @freq_subday_interval = 10, -- Cada 10 minutos (mínimo válido)
        @active_start_time = 000000,
        @active_end_time = 235959;
    
    PRINT '[✓] Schedule ''Cada_10_Minutos_AlertasBloqueos'' creado exitosamente.';
END
ELSE
    PRINT '[ℹ] Schedule ''Cada_10_Minutos_AlertasBloqueos'' ya existe.';
GO

-- ==================== CREAR JOB SI NO EXISTE ====================
IF NOT EXISTS (SELECT 1 FROM sysjobs WHERE name = 'DBA_usp_alertar_bloqueos')
BEGIN
    DECLARE @JobID UNIQUEIDENTIFIER;
    
    EXEC sp_add_job
        @job_name = 'DBA_usp_alertar_bloqueos',
        @enabled = 1,
        @description = 'Ejecuta usp_alertar_bloqueos cada 5 minutos para detectar bloqueos y queries largas. Envía alertas por email.',
        @job_id = @JobID OUTPUT;
    
    PRINT '[✓] Job ''DBA_usp_alertar_bloqueos'' creado exitosamente.';
    
    -- ==================== CREAR PASO DEL JOB ====================
    EXEC sp_add_jobstep
        @job_name = 'DBA_usp_alertar_bloqueos',
        @step_name = 'Ejecutar_usp_alertar_bloqueos',
        @subsystem = 'TSQL',
        @database_name = 'sqlmant',
        @command = N'EXEC sqlmant.dbo.usp_alertar_bloqueos;',
        @retry_attempts = 1,
        @retry_interval = 1,
        @on_success_action = 1, -- Ir al siguiente paso
        @on_fail_action = 2; -- Ir al siguiente paso en caso de error (no frenar)
    
    PRINT '[✓] Paso ''Ejecutar_usp_alertar_bloqueos'' creado exitosamente.';
    
    -- ==================== ASIGNAR SCHEDULE AL JOB ====================
    EXEC sp_attach_schedule
        @job_name = 'DBA_usp_alertar_bloqueos',
        @schedule_name = 'Cada_10_Minutos_AlertasBloqueos';
    
    PRINT '[✓] Schedule asignado al job exitosamente.';
    
    -- ==================== ASIGNAR JOB AL SERVIDOR ====================
    EXEC sp_add_jobserver
        @job_name = 'DBA_usp_alertar_bloqueos',
        @server_name = N'(local)';
    
    PRINT '[✓] Job asignado al servidor local exitosamente.';
END
ELSE
    PRINT '[ℹ] Job ''DBA_usp_alertar_bloqueos'' ya existe. Verificando pasos...';
    
    -- Verificar si el paso existe
    IF NOT EXISTS (SELECT 1 FROM sysjobsteps WHERE job_id = (SELECT job_id FROM sysjobs WHERE name = 'DBA_usp_alertar_bloqueos') AND step_name = 'Ejecutar_usp_alertar_bloqueos')
    BEGIN
        EXEC sp_add_jobstep
            @job_name = 'DBA_usp_alertar_bloqueos',
            @step_name = 'Ejecutar_usp_alertar_bloqueos',
            @subsystem = 'TSQL',
            @database_name = 'sqlmant',
            @command = N'EXEC sqlmant.dbo.usp_alertar_bloqueos;',
            @retry_attempts = 1,
            @retry_interval = 1,
            @on_success_action = 1,
            @on_fail_action = 2;
        
        PRINT '[✓] Paso agregado al job existente.';
    END
    ELSE
        PRINT '[ℹ] Paso ''Ejecutar_usp_alertar_bloqueos'' ya existe.';
GO

