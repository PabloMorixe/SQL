/* =======================================================================
   ANALÍTICAS COMPLETAS SOBRE sessions_alert4
   Autor: Pablo + Copilot
   Objetivo: analizar carga, tendencias, consumo y anomalías de sesiones
   ======================================================================= */
   select * FROM SqlMant.dbo.sessions_alert4
------------------------------------------------------------
-- 1) TENDENCIA GENERAL
------------------------------------------------------------
SELECT    host_name,
    program_name,
    login_name,
    capture_time,
    num_sessions
FROM SqlMant.dbo.sessions_alert4
ORDER BY capture_time DESC;

------------------------------------------------------------
-- 2) SESIONES POR BASE
------------------------------------------------------------
SELECT 
    DB,
    AVG(num_sessions) AS promedio_sesiones,
    MAX(num_sessions) AS max_sesiones,
    MIN(num_sessions) AS min_sesiones,
    COUNT(*) AS muestras
FROM SqlMant.dbo.sessions_alert4
GROUP BY DB
ORDER BY promedio_sesiones DESC;

------------------------------------------------------------
-- 3) SESIONES POR HORA
------------------------------------------------------------
SELECT 
    DATEPART(HOUR, capture_time) AS hora_del_dia,
    AVG(num_sessions) AS promedio,
    MAX(num_sessions) AS pico
FROM SqlMant.dbo.sessions_alert4
GROUP BY DATEPART(HOUR, capture_time)
ORDER BY hora_del_dia;

------------------------------------------------------------
-- 4) TOP CPU
------------------------------------------------------------
SELECT TOP 20
    host_name, program_name, login_name, DB, cpu_time_ms, capture_time
FROM SqlMant.dbo.sessions_alert4
ORDER BY cpu_time_ms DESC;

------------------------------------------------------------
-- 5) TOP WAITS
------------------------------------------------------------
SELECT TOP 20
    host_name, program_name, login_name, DB, wait_type, wait_time_ms, capture_time
FROM SqlMant.dbo.sessions_alert4
WHERE wait_time_ms IS NOT NULL
ORDER BY wait_time_ms DESC;

------------------------------------------------------------
-- 6) TOP IO
------------------------------------------------------------
SELECT TOP 20 host_name, program_name, login_name, DB, logical_reads, capture_time
FROM SqlMant.dbo.sessions_alert4
ORDER BY logical_reads DESC;

SELECT TOP 20 host_name, program_name, login_name, DB, reads, capture_time
FROM SqlMant.dbo.sessions_alert4
ORDER BY reads DESC;

SELECT TOP 20 host_name, program_name, login_name, DB, writes, capture_time
FROM SqlMant.dbo.sessions_alert4
ORDER BY writes DESC;

------------------------------------------------------------
-- 7) Z-SCORE
------------------------------------------------------------
;WITH baseline AS (
    SELECT capture_time, num_sessions,
           AVG(num_sessions) OVER() AS mean_ses,
           STDEV(num_sessions) OVER() AS stdev_ses
    FROM SqlMant.dbo.sessions_alert4
)
SELECT *, (num_sessions - mean_ses) / NULLIF(stdev_ses,0) AS z_score
FROM baseline
ORDER BY capture_time DESC;

------------------------------------------------------------
-- 8) ANOMALÍAS
------------------------------------------------------------
;WITH baseline AS (
    SELECT capture_time, num_sessions,
           AVG(num_sessions) OVER() AS mean_ses,
           STDEV(num_sessions) OVER() AS stdev_ses
    FROM SqlMant.dbo.sessions_alert4
)
SELECT *, (num_sessions - mean_ses) / NULLIF(stdev_ses,0) AS z_score
FROM baseline
WHERE ABS((num_sessions - mean_ses) / NULLIF(stdev_ses,0)) >= 3
ORDER BY capture_time DESC;

