		@command=N'-- Agregar esto como un segundo paso en tu Job
DELETE FROM [SqlMant].[dbo].[sessions_alert2] 
WHERE [capture_time] < DATEADD(day, -90, GETDATE());', 
		@database_name=N'SqlMant', 
		@flags=0
