/* ***********************************************************************
   1) TENDENCIA DE SESIONES POR HOST / PROGRAMA / LOGIN
   *********************************************************************** */
-- Muestra cómo evolucionan las sesiones capturadas a lo largo del tiempo
-- Útil para ver patrones de comportamiento por aplicación y usuario
SELECT 
    host_name,
    program_name,
    login_name,
    capture_time,
    num_sessions
FROM SqlMant.dbo.sessions_alert3
ORDER BY capture_time DESC;



/* ***********************************************************************
   2) SESIONES POR BASE DE DATOS
   *********************************************************************** */
-- Promedio, máximo, mínimo y cantidad de muestras por base
-- Permite ver qué bases reciben más carga de sesiones
SELECT 
    DB,
    AVG(num_sessions) AS promedio_sesiones,
    MAX(num_sessions) AS max_sesiones,
    MIN(num_sessions) AS min_sesiones,
    COUNT(*) AS muestras
FROM SqlMant.dbo.sessions_alert3
GROUP BY DB
ORDER BY promedio_sesiones DESC;



/* ***********************************************************************
   3) SESIONES POR HORA DEL DÍA
   *********************************************************************** */
-- Identifica en qué horas del día hay mayor actividad
-- Ideal para capacity planning
SELECT 
    DATEPART(HOUR, capture_time) AS hora_del_dia,
    AVG(num_sessions) AS promedio,
    MAX(num_sessions) AS pico
FROM SqlMant.dbo.sessions_alert3
GROUP BY DATEPART(HOUR, capture_time)
ORDER BY hora_del_dia;



/* ***********************************************************************
   4) SESIONES CON MAYOR CPU CONSUMIDA
   *********************************************************************** */
-- Top consumidores de CPU (sumatoria por captura)
SELECT TOP 20
    host_name,
    program_name,
    login_name,
    DB,
    cpu_time_ms,
    capture_time
FROM SqlMant.dbo.sessions_alert3
ORDER BY cpu_time_ms DESC;



/* ***********************************************************************
   5) SESIONES CON MAYORES WAITS
   *********************************************************************** */
-- Muestra los waits más pesados asociados a sesiones
-- Ideal para detectar problemas de performance
SELECT TOP 20
    host_name,
    program_name,
    login_name,
    DB,
    wait_type,
    wait_time_ms,
    capture_time
FROM SqlMant.dbo.sessions_alert3
WHERE wait_time_ms IS NOT NULL
ORDER BY wait_time_ms DESC;



/* ***********************************************************************
   6) TOP CONSUMIDORES DE I/O (READS / WRITES / LOGICAL READS)
   *********************************************************************** */

-- 6A: TOP Logical Reads
SELECT TOP 20
    host_name,
    program_name,
    login_name,
    DB,
    logical_reads,
    capture_time
FROM SqlMant.dbo.sessions_alert3
ORDER BY logical_reads DESC;

-- 6B: TOP Reads (lecturas físicas)
SELECT TOP 20
    host_name,
    program_name,
    login_name,
    DB,
    reads,
    capture_time
FROM SqlMant.dbo.sessions_alert3
ORDER BY reads DESC;

-- 6C: TOP Writes
SELECT TOP 20
    host_name,
    program_name,
    login_name,
    DB,
    writes,
    capture_time
ORDER BY writes DESC;



/* ***********************************************************************
   7) DETECCIÓN DE ANOMALÍAS (Z-SCORE)
   *********************************************************************** */
-- Calcula la media y desviación estándar global de sesiones
-- Luego calcula Z-score: cuántas desviaciones se aleja un valor del promedio
-- Z >= 3 o Z <= -3 = anomalía estadística

;WITH baseline AS (
    SELECT 
        capture_time,
        num_sessions,
        AVG(num_sessions) OVER() AS mean_ses,
        STDEV(num_sessions) OVER() AS stdev_ses
    FROM SqlMant.dbo.sessions_alert3
)
SELECT
    capture_time,
    num_sessions,
    mean_ses,
    stdev_ses,
    (num_sessions - mean_ses) / NULLIF(stdev_ses,0) AS z_score
FROM baseline
ORDER BY capture_time DESC;



/* ***********************************************************************
   8) DETECCIÓN DE ANOMALÍAS REALES (Z >= 3)
   *********************************************************************** */
-- Picos anómalos reales
;WITH baseline AS (
    SELECT 
        capture_time,
        num_sessions,
        AVG(num_sessions) OVER() AS mean_ses,
        STDEV(num_sessions) OVER() AS stdev_ses
    FROM SqlMant.dbo.sessions_alert3
)
SELECT
    capture_time,
    num_sessions,
    mean_ses,
    stdev_ses,
    (num_sessions - mean_ses) / NULLIF(stdev_ses,0) AS z_score
FROM baseline
WHERE ABS((num_sessions - mean_ses) / NULLIF(stdev_ses,0)) >= 3
ORDER BY capture_time DESC;

